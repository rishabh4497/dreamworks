rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default: deny all. Each collection opts in explicitly.
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Shared helpers ──────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function ownsByPrefix(docId) {
      return isSignedIn() && docId.matches(request.auth.uid + '_.*');
    }
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // ── AI (server-only) ────────────────────────────────────────────────
    // Only Cloud Functions running with the Admin SDK can touch these.
    match /dw_ai_cache/{cacheKey}   { allow read, write: if false; }
    match /dw_ai_quotas/{uid}       { allow read, write: if false; }
    match /dw_ai_usage/{eventId}    { allow read, write: if false; }

    // ── User profiles ───────────────────────────────────────────────────
    // Public read for profile cards (friend list, reviews, etc.). Self-write
    // is allowed but role/permissions/suspended must be unchanged client-side
    // — those are only ever set by setUserRole / claimAdminIfAllowlisted
    // Cloud Functions (or by an admin from the admin console).
    match /users/{uid} {
      allow read: if true;
      allow create: if isOwner(uid)
        && (!("role" in request.resource.data)
            || request.resource.data.role == "user");
      allow update: if isAdmin()
        || (isOwner(uid)
            && (!("role" in request.resource.data)
                || request.resource.data.role == resource.data.get("role", "user"))
            && (!("permissions" in request.resource.data)
                || request.resource.data.permissions == resource.data.get("permissions", []))
            && (!("suspended" in request.resource.data)
                || request.resource.data.suspended == resource.data.get("suspended", false)));
      allow delete: if false;
    }

    // ── Public catalog ──────────────────────────────────────────────────
    // Public read so unauthenticated landing pages render. Writes only via
    // admins (callables run with Admin SDK, bypassing rules).
    match /dw_games/{gameId}       { allow read: if true; allow write: if isAdmin(); }
    match /dw_categories/{slug}    { allow read: if true; allow write: if isSignedIn(); }
    match /dw_tags/{slug}          { allow read: if true; allow write: if isSignedIn(); }
    match /dw_news/{slug}          { allow read: if true; allow write: if isSignedIn(); }
    match /dw_reviews/{reviewId}   {
      allow read: if true;
      // Reviews must include the author's uid as `userId` for the per-user
      // store subscription to work; only the author can write/update their
      // own review.
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
                    && resource.data.userId == request.auth.uid;
    }
    match /dw_forum_threads/{threadId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn()
                    && resource.data.authorUid == request.auth.uid;
    }
    match /dw_forum_replies/{replyId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn()
                    && resource.data.authorUid == request.auth.uid;
    }

    // ── Social feed ─────────────────────────────────────────────────────
    match /dw_feed/{postId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn()
                    && resource.data.authorUid == request.auth.uid;
    }

    // ── Friends graph (shared demo data for v1) ─────────────────────────
    match /dw_friends/{friendId}          { allow read: if true; allow write: if isSignedIn(); }
    match /dw_friend_activity/{eventId}   { allow read: if true; allow write: if isSignedIn(); }
    match /dw_friend_owned/{friendId}     { allow read: if true; allow write: if isSignedIn(); }

    // ── Per-user owned data ─────────────────────────────────────────────
    match /dw_library/{docId} {
      allow read, write: if isSignedIn()
                       && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    match /dw_wishlist/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if isSignedIn()
                       && request.resource.data.userId == request.auth.uid;
    }
    match /dw_collections/{collectionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
                       && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
                       && resource.data.userId == request.auth.uid;
    }
    match /dw_orders/{orderId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
                       && request.resource.data.userId == request.auth.uid;
    }
    match /dw_carts/{uid} {
      allow read, write: if isOwner(uid);
    }
    match /dw_notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn()
                       && resource.data.userId == request.auth.uid;
    }
    match /dw_cloud_saves/{slotId} {
      allow read, write: if ownsByPrefix(slotId);
    }
    match /dw_compatibility/{docId} {
      allow read, write: if ownsByPrefix(docId);
    }
    match /dw_downloads/{docId} {
      allow read, write: if ownsByPrefix(docId);
    }
    match /dw_user_settings/{uid} {
      allow read, write: if isOwner(uid);
    }
    match /dw_user_hardware/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ── Developer portal ────────────────────────────────────────────────
    // Store pages are publicly readable. Owners may freely edit content
    // while their app is in draft; stage/submissionStatus/latestSubmissionId
    // transitions are server-side only (callable Cloud Functions:
    // submitAppForReview, reviewAppSubmission, publishApprovedApp). Admins
    // may write anything.
    match /dw_apps/{appId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.ownerUserId == request.auth.uid
        && request.resource.data.stage == "draft";
      allow update: if isAdmin() || (
        isSignedIn()
        && resource.data.ownerUserId == request.auth.uid
        && resource.data.stage == "draft"
        && (!("stage" in request.resource.data)
            || request.resource.data.stage == "draft")
        && (!("submissionStatus" in request.resource.data)
            || request.resource.data.submissionStatus == resource.data.get("submissionStatus", "none"))
        && (!("latestSubmissionId" in request.resource.data)
            || request.resource.data.latestSubmissionId == resource.data.get("latestSubmissionId", null))
      );
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.ownerUserId == request.auth.uid && resource.data.stage == "draft");
    }
    match /dw_apps/{appId}/builds/{buildId} {
      allow read: if true;
      allow write: if isAdmin()
        || (isSignedIn() && get(/databases/$(database)/documents/dw_apps/$(appId)).data.ownerUserId == request.auth.uid);
    }
    match /dw_apps/{appId}/achievements/{achId} {
      allow read: if true;
      allow write: if isAdmin()
        || (isSignedIn() && get(/databases/$(database)/documents/dw_apps/$(appId)).data.ownerUserId == request.auth.uid);
    }
    match /dw_developers/{devId} {
      allow read: if true;
      allow write: if isAdmin()
        || (isSignedIn()
            && resource.data.ownerUserId == request.auth.uid
            && (!("verificationStatus" in request.resource.data)
                || request.resource.data.verificationStatus == resource.data.get("verificationStatus", "unverified")));
    }
    match /dw_publishers/{pubId} {
      allow read: if true;
      allow write: if isAdmin()
        || (isSignedIn()
            && resource.data.ownerUserId == request.auth.uid
            && (!("verificationStatus" in request.resource.data)
                || request.resource.data.verificationStatus == resource.data.get("verificationStatus", "unverified")));
    }
    match /dw_developer_drafts/{draftId} {
      allow read, write: if isSignedIn();
    }

    // ── Admin: app submissions, audit log, profile-claim submissions ────
    // Source of truth for review state. Created/updated only by Cloud
    // Functions; clients may read their own submissions, admins read all.
    match /dw_app_submissions/{id} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.submitterUserId == request.auth.uid);
      allow write: if false;
    }
    match /dw_publisher_submissions/{id} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.submitterUserId == request.auth.uid);
      allow write: if false;
    }
    match /dw_developer_submissions/{id} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.submitterUserId == request.auth.uid);
      allow write: if false;
    }
    match /dw_admin_audit/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }
    match /dw_moderation_records/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Telemetry (Console / observability backbone) ────────────────────
    // Signed-in users write their own session/event/error/perf records;
    // session updates (e.g. endedAt, lastRoute) are also self-write. All
    // reads gated to admins so we never leak event history client-side.
    match /dw_telemetry_sessions/{id} {
      allow read, list: if isAdmin();
      allow create, update: if isSignedIn()
                            && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }
    match /dw_telemetry_events/{id} {
      allow read, list: if isAdmin();
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }
    match /dw_telemetry_errors/{id} {
      allow read, list: if isAdmin();
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }
    match /dw_telemetry_perf/{id} {
      allow read, list: if isAdmin();
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }
    match /dw_telemetry_devices/{uid} {
      allow read, list: if isAdmin();
      allow write: if isOwner(uid)
                   && request.resource.data.uid == request.auth.uid;
    }

    // ── Privacy: per-user launcher scan history ─────────────────────────
    // Subcollection under the user doc. Self read/write only — never exposed
    // to other users, never readable by admin via security rules (only via
    // server-side admin SDK).
    match /users/{uid}/scan_history/{docId} {
      allow read, write: if isOwner(uid);
    }

    // ── Privacy: account deletion queue ─────────────────────────────────
    // User schedules deletion by writing their own uid-keyed doc. A Cloud
    // Function (or admin) consumes the queue and performs the actual purge
    // with elevated privileges. Clients cannot read other users' requests.
    match /dw_deletion_requests/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ── Console operator surface ────────────────────────────────────────
    match /dw_console_annotations/{id} {
      allow read, list: if isAdmin();
      allow create, update, delete: if isAdmin()
                                    && request.resource.data.authorUid == request.auth.uid;
    }
    match /dw_console_error_issues/{fingerprint} {
      allow read, list, write: if isAdmin();
    }
    match /dw_console_saved_views/{id} {
      allow read, list: if isAdmin();
      allow create, update, delete: if isAdmin()
                                    && request.resource.data.ownerUid == request.auth.uid;
    }
    match /dw_console_insights/{id} {
      allow read, list, write: if isAdmin();
    }

    // ── Per-actor telemetry rollups ─────────────────────────────────────
    // Users may read their own rollup so Dreamworks Wrapped can render
    // without scanning raw events. App + publisher rollups are non-PII
    // aggregates — safe to expose for self-service in the developer portal.
    match /dw_telemetry_user_rollups/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isAdmin();
    }
    match /dw_telemetry_app_rollups/{appId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /dw_telemetry_publisher_rollups/{publisherId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Session replay (admin-only reads, self-write) ──────────────────
    match /dw_telemetry_replays/{id} {
      allow read, list: if isAdmin();
      allow create, update: if isSignedIn()
                            && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ── Funnels (admin-managed configuration) ───────────────────────────
    match /dw_console_funnels/{id} {
      allow read, list, write: if isAdmin();
    }

    // ── A/B Experiments (admin-managed) ─────────────────────────────────
    match /dw_console_experiments/{id} {
      // Public read so feature-flag clients can resolve variants without
      // an admin token. Writes are admin-only.
      allow read, list: if true;
      allow write: if isAdmin();
    }

    // ── Alerts: rules + events (admin-managed) ──────────────────────────
    match /dw_console_alert_rules/{id} {
      allow read, list, write: if isAdmin();
    }
    match /dw_console_alert_events/{id} {
      allow read, list, write: if isAdmin();
    }

    // ── Deploy markers (admin-managed) ──────────────────────────────────
    match /dw_console_deploys/{id} {
      allow read, list, write: if isAdmin();
    }

    // ── Voice QoS samples (self-write, admin-read) ──────────────────────
    match /dw_voice_qos_samples/{id} {
      allow read, list: if isAdmin();
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Fraud signals (admin-only reads + writes) ───────────────────────
    match /dw_fraud_signals/{id} {
      allow read, list, write: if isAdmin();
    }

    // ── Auth anomalies (admin-only) ─────────────────────────────────────
    match /dw_auth_anomalies/{id} {
      allow read, list, write: if isAdmin();
    }

    // ── Console queries + dashboards (admin-managed) ────────────────────
    match /dw_console_queries/{id} {
      allow read, list: if isAdmin();
      allow create, update, delete: if isAdmin()
                                    && request.resource.data.ownerUid == request.auth.uid;
    }
    match /dw_console_dashboards/{id} {
      allow read, list: if isAdmin();
      allow create, update, delete: if isAdmin()
                                    && request.resource.data.ownerUid == request.auth.uid;
    }

    // ── Email pipeline events (admin-read; usually server-written) ──────
    match /dw_email_events/{id} {
      allow read, list: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ── Referral invites (self-write) ───────────────────────────────────
    match /dw_referrals/{id} {
      allow read, list: if isAdmin();
      allow create: if isSignedIn()
                    && request.resource.data.inviterUid == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }
  }
}
