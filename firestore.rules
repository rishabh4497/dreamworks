rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default: deny all. Each collection opts in explicitly.
    match /{document=**} {
      allow read, write: if false;
    }

    // ── AI (server-only) ────────────────────────────────────────────────
    // Only Cloud Functions running with the Admin SDK can touch these.
    match /dw_ai_cache/{cacheKey}   { allow read, write: if false; }
    match /dw_ai_quotas/{uid}       { allow read, write: if false; }
    match /dw_ai_usage/{eventId}    { allow read, write: if false; }

    // ── User profiles ───────────────────────────────────────────────────
    // Owner may read/write own profile; others may read (for public profile
    // cards on game pages, friends list, etc.).
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Public catalog ──────────────────────────────────────────────────
    // Public read so unauthenticated landing pages render. Writes only via
    // an authenticated session (developer portal / admin seeding).
    match /dw_games/{gameId}       { allow read: if true; allow write: if request.auth != null; }
    match /dw_categories/{slug}    { allow read: if true; allow write: if request.auth != null; }
    match /dw_tags/{slug}          { allow read: if true; allow write: if request.auth != null; }
    match /dw_news/{slug}          { allow read: if true; allow write: if request.auth != null; }
    match /dw_reviews/{reviewId}   {
      allow read: if true;
      // Reviews must include the author's uid as `userId` for the per-user
      // store subscription to work; only the author can write/update their
      // own review.
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }
    match /dw_forum_threads/{threadId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
                    && resource.data.authorUid == request.auth.uid;
    }
    match /dw_forum_replies/{replyId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
                    && resource.data.authorUid == request.auth.uid;
    }

    // ── Social feed ─────────────────────────────────────────────────────
    // Posts publicly readable; any authenticated user can create. Likes /
    // reposts are array mutations on the post doc, so updates are open to
    // any signed-in user. The author is the only one who can delete.
    match /dw_feed/{postId} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null
                    && resource.data.authorUid == request.auth.uid;
    }

    // ── Friends graph (shared demo data for v1) ─────────────────────────
    // Treated as public-read, authenticated-write while the graph stays
    // global. When per-user graphs land, replace with subcollections under
    // dw_friends/{userId}/items/{friendId}.
    match /dw_friends/{friendId}          { allow read: if true; allow write: if request.auth != null; }
    match /dw_friend_activity/{eventId}   { allow read: if true; allow write: if request.auth != null; }
    match /dw_friend_owned/{friendId}     { allow read: if true; allow write: if request.auth != null; }

    // ── Per-user owned data ─────────────────────────────────────────────
    // Doc IDs follow the convention `{uid}_{...}` so we can scope by prefix.
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }
    function ownsByPrefix(docId) {
      return request.auth != null && docId.matches(request.auth.uid + '_.*');
    }

    match /dw_library/{docId} {
      allow read, write: if request.auth != null
                       && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    match /dw_wishlist/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if request.auth != null
                       && request.resource.data.userId == request.auth.uid;
    }
    match /dw_collections/{collectionId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                       && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
                       && resource.data.userId == request.auth.uid;
    }
    match /dw_orders/{orderId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                       && request.resource.data.userId == request.auth.uid;
    }
    match /dw_carts/{uid} {
      allow read, write: if isOwner(uid);
    }
    match /dw_notifications/{notifId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
                       && resource.data.userId == request.auth.uid;
    }
    match /dw_cloud_saves/{slotId} {
      allow read, write: if ownsByPrefix(slotId);
    }
    match /dw_compatibility/{docId} {
      allow read, write: if ownsByPrefix(docId);
    }
    match /dw_downloads/{docId} {
      allow read, write: if ownsByPrefix(docId);
    }
    match /dw_user_settings/{uid} {
      allow read, write: if isOwner(uid);
    }
    match /dw_user_hardware/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ── Developer portal (owned by separate agent) ──────────────────────
    // Permissive while the dev-portal flow is iterated on; tighten when
    // ownership models stabilize.
    match /dw_apps/{appId}                       { allow read, write: if request.auth != null; }
    match /dw_apps/{appId}/builds/{buildId}      { allow read, write: if request.auth != null; }
    match /dw_apps/{appId}/achievements/{achId}  { allow read, write: if request.auth != null; }
    match /dw_developers/{devId}                 { allow read: if true; allow write: if request.auth != null; }
    match /dw_publishers/{pubId}                 { allow read: if true; allow write: if request.auth != null; }
    match /dw_developer_drafts/{draftId}         { allow read, write: if request.auth != null; }
  }
}
